# Copy this file to `.env` for local development.
#
# VITE_API_URL controls where the frontend sends API requests.
# - Leave empty / unset to use the Vite dev proxy (recommended for local dev).
#   The proxy at /api forwards to http://127.0.0.1:8000 (see vite.config.ts).
# - Set to a full URL for production:
#   * Self-host: same origin as the page (e.g. http://localhost:8000 when the
#     backend also serves the built frontend from /).
#   * Split deploy: https://<backend-host>:<port>
#
# Note: Vite reads VITE_* env vars at BUILD time. After changing this file,
# restart `npm run dev` (or rebuild) for changes to take effect.

# VITE_API_URL=http://localhost:8000

# Application Name
VITE_APP_NAME=LocalIntel AI

# Environment
VITE_ENV=development

# Upload size limit (MB) — informational; the backend enforces this
VITE_MAX_UPLOAD_MB=100
