# Copy this file to `.env` for local development.
# On Railway, set `VITE_API_URL` in the frontend service's Variables tab to
# the backend's public Railway URL (build-time substitution via Vite).

# Backend API URL (no trailing slash)
VITE_API_URL=http://127.0.0.1:8000

# Application Name
VITE_APP_NAME=LocalIntel AI

# Environment
VITE_ENV=development

# Upload size limit (MB)
VITE_MAX_UPLOAD_MB=100
